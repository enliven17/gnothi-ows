# GenLayer -> EVM (polling)
FORWARDER_NETWORK_RPC_URL=https://sepolia.era.zksync.dev
GENLAYER_RPC_URL=https://studio.genlayer.com/api
BRIDGE_FORWARDER_ADDRESS=
BRIDGE_SENDER_ADDRESS=
BRIDGE_SYNC_INTERVAL=*/5 * * * *

# EVM -> GenLayer (event polling, optional)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BET_FACTORY_ADDRESS=
MOCK_USDL_ADDRESS=

# Path to intelligent oracles (for deployment environments)
ORACLES_PATH=/app/intelligent-oracles

# Auth
PRIVATE_KEY=

# Supabase (persistence for oracle registry + resolution queue)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# HTTP API port (Railway sets PORT automatically)
HTTP_PORT=3001

# XMTP MarketBot — separate wallet for the bot identity
# Generate with: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
XMTP_BOT_PRIVATE_KEY=
