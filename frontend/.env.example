# Privy Configuration
# Get your App ID from https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

NEXT_PUBLIC_BET_FACTORY_ADDRESS=

NEXT_PUBLIC_OWNER_ADDRESS=

NEXT_PUBLIC_BRIDGE_SERVICE_URL=

# MoonPay — get API key from https://dashboard.moonpay.com
NEXT_PUBLIC_MOONPAY_API_KEY=

# OWS (Open Wallet Standard) — server-side only, never expose to client
# Keys are stored locally in ~/.ows/ by the OWS CLI
# No env var needed for basic usage; set for programmatic key management
# OWS_WALLET_NAME=gnothi-agent-treasury